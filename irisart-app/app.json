{
  "expo": {
    "name": "irisart-app",
    "slug": "irisart-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "irisartapp",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "IrisArt uses the camera to capture a close-up photo of your iris for color analysis and artwork generation.",
        "NSPhotoLibraryUsageDescription": "IrisArt uses your photo library to let you select a close-up image of your iris for analysis."
      }
    },
    "android": {
      "permissions": [
        "CAMERA",
        "FLASHLIGHT"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow IrisArt to access your camera for iris capture.",
          "microphonePermission": "Allow IrisArt to access your microphone.",
          "recordAudioAndroid": false
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}

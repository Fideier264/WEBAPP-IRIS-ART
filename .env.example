# Kopiere diese Datei nach .env im Projektroot und trage echte Werte ein.
# .env wird von Git ignoriert — niemals Secrets committen.

# Supabase (öffentlich in der App — Anon Key ist client-seitig)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# merchOne Blueprint-SKUs (öffentlich, aus dem merchOne-Dashboard)
EXPO_PUBLIC_MERCHONE_SKU_CANVAS_30CM=
EXPO_PUBLIC_MERCHONE_SKU_CANVAS_60CM=

# Nur für lokale Supabase-CLI / Dokumentation — echte Secrets gehören in
# Supabase Dashboard → Edge Functions → Secrets (nicht in Git):
# REPLICATE_API_TOKEN=
# NANO_BANANA_2_API_KEY=
# MERCHONE_API_USER=
# MERCHONE_API_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
